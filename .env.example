# --- Database (MongoDB Atlas — free M0) ---
# Create a cluster at https://www.mongodb.com/atlas and paste the connection string.
# Works for both local dev and Vercel. Include the database name in the path.
DATABASE_URL="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/stride?retryWrites=true&w=majority"

# --- Hevy (Pro account) ---
# Get a key at https://hevy.com/settings?developer
HEVY_API_KEY=""

# --- Strava (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
# Where Strava redirects after consent. Local + prod variants:
#   http://localhost:3000/api/auth/strava/callback
#   https://YOUR-APP.vercel.app/api/auth/strava/callback
STRAVA_REDIRECT_URI="http://localhost:3000/api/auth/strava/callback"

# --- Cron / sync auth ---
# Random secret; Vercel Cron and the "Sync now" button send it as a Bearer token.
CRON_SECRET=""

# --- Dashboard password gate ---
# Set this to require a password to view/edit the dashboard. Leave empty to
# disable auth (e.g. local-only). Required before deploying publicly.
DASHBOARD_PASSWORD=""

# Public base URL (used for building OAuth redirect in some flows). Optional locally.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
