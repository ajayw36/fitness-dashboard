// Stride fitness dashboard — data synced from Hevy (lifting) and Strava (running).
// MongoDB via Prisma 6 (Prisma 7 does not yet support MongoDB).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is for Vercel's Linux runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// A Hevy workout session.
model Workout {
  id        String        @id @map("_id") // Hevy workout id
  title     String
  startTime DateTime
  endTime   DateTime?
  raw       Json
  sets      ExerciseSet[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([startTime])
}

/// A single performed set, normalized out of a Hevy workout for fast querying.
model ExerciseSet {
  id           String   @id @default(cuid()) @map("_id")
  workout      Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId    String
  exerciseName String
  setIndex     Int
  weightKg     Float?
  reps         Int?
  performedAt  DateTime

  @@index([exerciseName, performedAt])
  @@index([workoutId])
}

/// A Strava activity (runs are what we surface, but we keep type for filtering).
model Run {
  id            String   @id @map("_id") // Strava activity id (as string)
  name          String
  type          String
  startDate     DateTime
  distanceM     Float
  movingTimeS   Int
  elapsedS      Int?
  calories      Float?
  bestEfforts   Json? // best_efforts array from the detailed activity
  splits        Json? // splits_metric array
  polyline      String? // encoded GPS route (map.polyline / summary_polyline)
  detailFetched Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([startDate])
  @@index([type, startDate])
}

/// Body weight (and other) measurements from Hevy /v1/body_measurements.
model BodyMeasurement {
  id        String   @id @default(cuid()) @map("_id")
  date      DateTime @unique
  weightKg  Float
  createdAt DateTime @default(now())
}

/// OAuth tokens (Strava). Single row per provider.
model OAuthToken {
  provider     String   @id @map("_id") // e.g. "strava"
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  athleteId    String?
  updatedAt    DateTime @updatedAt
}

/// Incremental sync bookkeeping, one row per provider.
model SyncState {
  provider     String    @id @map("_id") // "hevy" | "strava"
  lastSyncedAt DateTime?
  cursor       String? // hevy events page / strava `after` epoch seconds
  lastError    String?
  updatedAt    DateTime  @updatedAt
}

/// Generic key/value settings (goal weight, key lifts list, etc.).
model Setting {
  key   String @id @map("_id")
  value Json
}
